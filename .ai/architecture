### 4.3 Error Handling Strategy
```kotlin
// Используем sealed classes для типизированных ошибок
sealed class AIError(message: String, cause: Throwable? = null) : Exception(message, cause) {
    class ConfigurationError(message: String, cause: Throwable? = null) : AIError(message, cause)
    class NetworkError(message: String, cause: Throwable? = null) : AIError(message, cause)
    class AuthenticationError(message: String, cause: Throwable? = null) : AIError(message, cause)
    class RateLimitError(message: String, val retryAfter: Duration? = null) : AIError(message)
    class ModelNotAvailableError(message: String) : AIError(message)
    class InvalidRequestError(message: String) : AIError(message)
}

// Result wrapper для методов, которые могут неудачно завершиться
sealed class Result<out T> {
    data class Success<T>(val data: T) : Result<T>()
    data class Error(val exception: Throwable) : Result<Nothing>()
    
    inline fun <R> map(transform: (T) -> R): Result<R> = when (this) {
        is Success -> Success(transform(data))
        is Error -> this
    }
    
    inline fun onSuccess(action: (T) -> Unit): Result<T> {
        if (this is Success) action(data)
        return this
    }
    
    inline fun onError(action: (Throwable) -> Unit): Result<T> {
        if (this is Error) action(exception)
        return this
    }
}
```

### 4.4 Async Programming
```kotlin
// Используем coroutines для всех async операций
class AICliService {
    private val serviceScope = CoroutineScope(
        SupervisorJob() + Dispatchers.Default + 
        CoroutineName("AICliService")
    )
    
    suspend fun executeRequest(request: AIRequest): Result<AIResponse> = withContext(Dispatchers.IO) {
        try {
            Result.Success(provider.execute(request))
        } catch (e: Exception) {
            Result.Error(e)
        }
    }
    
    // Для UI операций используем EDT
    suspend fun updateUI(update: () -> Unit) = withContext(Dispatchers.EDT) {
        update()
    }
}
```

